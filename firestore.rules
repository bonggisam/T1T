rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuth() && getUserData().role in ['admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return isAuth() && getUserData().role == 'super_admin';
    }

    function isActive() {
      return isAuth() && getUserData().status == 'active';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow read: if isAdmin();

      // Signup: first user → super_admin (only if app_meta/initialized doesn't exist yet)
      // Subsequent users → teacher+pending only
      allow create: if isAuth() && request.auth.uid == userId
        && (
          (request.resource.data.role == 'super_admin'
           && request.resource.data.status == 'active'
           && !exists(/databases/$(database)/documents/app_meta/initialized))
          ||
          (request.resource.data.role == 'teacher'
           && request.resource.data.status == 'pending')
        );

      allow update: if isAuth() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status']);
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // Shared events
    match /events/{eventId} {
      allow read: if isActive();
      allow create, update, delete: if isAdmin() && isActive();
    }

    // Personal events
    match /personal_events/{userId}/events/{eventId} {
      allow read, write: if isAuth() && request.auth.uid == userId && isActive();
    }

    // App metadata — anyone auth can read, create only if doc doesn't exist
    match /app_meta/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // Notifications
    match /notifications/{userId}/items/{notificationId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
      allow create: if isAdmin();
    }
  }
}
