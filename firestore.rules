rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuth() && getUserData().role in ['admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return isAuth() && getUserData().role == 'super_admin';
    }

    function isActive() {
      return isAuth() && getUserData().status == 'active';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow read: if isAdmin();
      // Signup: just require auth + own uid (role logic handled by client + app_meta)
      allow create: if isAuth() && request.auth.uid == userId
        && (!('school' in request.resource.data) || request.resource.data.school in ['taeseong_middle', 'taeseong_high']);
      // 본인이 프로필 일부 수정 (role/status 변경 불가)
      allow update: if isAuth() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])
        && (!('school' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.school in ['taeseong_middle', 'taeseong_high']);
      // 관리자 수정 — school 값 whitelist 강제
      allow update: if isAdmin()
        && (!('school' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.school in ['taeseong_middle', 'taeseong_high']);
      allow delete: if isSuperAdmin();
    }

    // Shared events — all active users can create; edit/delete own only; admin can manage all
    // school 값 whitelist 검증 (스푸핑 방지)
    match /events/{eventId} {
      allow read: if isActive();
      allow create: if isActive()
        && request.resource.data.school in ['taeseong_middle', 'taeseong_high', 'all'];
      allow update, delete: if isActive()
        && (resource.data.createdBy == request.auth.uid || isAdmin())
        && (!('school' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.school in ['taeseong_middle', 'taeseong_high', 'all']);
    }

    // Personal events
    match /personal_events/{userId}/events/{eventId} {
      allow read, write: if isAuth() && request.auth.uid == userId && isActive();
    }

    // App metadata
    match /app_meta/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // Notifications — 본인만 읽고 업데이트 가능. 생성은 active 사용자 (멘션 알림용)
    match /notifications/{userId}/items/{notificationId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
      // createdBy를 본인 uid로만 생성 가능 (스푸핑 방지)
      allow create: if isActive() && request.resource.data.createdBy == request.auth.uid;
    }

    // Event comments (subcollection)
    match /events/{eventId}/comments/{commentId} {
      allow read: if isActive();
      allow create: if isActive() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Todos — userId == 본인만 읽기/쓰기 가능
    match /todos/{todoId} {
      allow read: if isActive() && resource.data.userId == request.auth.uid;
      allow create: if isActive() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
